{
  "name": "quanta-control",
  "version": "0.1.0",
  "description": "Local-first Git and GitHub control panel for working repositories.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "quanta-control": "./bin/quanta-control.js"
  },
  "files": [
    "bin",
    "build",
    "dist",
    "scripts/install.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:cli": "node ./bin/quanta-control-dev.js",
    "dev:client": "vite",
    "dev:desktop": "npx electron ./electron/main.js",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node ./build/server/index.js",
    "start:cli": "node ./bin/quanta-control.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "diff": "^7.0.0",
    "express": "^5.1.0",
    "lucide-react": "^0.488.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/cors": "^2.8.17",
    "@types/diff": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^41.2.1",
    "eslint": "^9.24.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
