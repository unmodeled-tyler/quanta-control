{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "outDir": "./build/server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/**/*.ts", "src/types/**/*.ts"]
}
